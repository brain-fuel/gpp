{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "G++",
  "scopeName": "source.gpp",
  "fileTypes": ["gpp"],
  "patterns": [
    { "include": "#gpp-keywords" },
    { "include": "#gpp-operators" },
    { "include": "#gpp-quantities" },
    { "include": "#gpp-directives" },
    { "include": "source.go" }
  ],
  "repository": {
    "gpp-keywords": {
      "patterns": [
        {
          "comment": "gpp declaration keywords (contextual)",
          "match": "\\b(enum|match|class|instance|law|total|delegate|nat|mult|refl)\\b",
          "name": "keyword.control.gpp"
        },
        {
          "comment": "Eq proposition type",
          "match": "\\bEq(?=\\[)",
          "name": "support.type.gpp"
        }
      ]
    },
    "gpp-operators": {
      "patterns": [
        { "match": "\\|>", "name": "keyword.operator.pipeline.gpp" },
        { "match": ">=>", "name": "keyword.operator.kleisli.gpp" },
        { "match": "(?<=[)\\w])\\?", "name": "keyword.operator.try.gpp" }
      ]
    },
    "gpp-quantities": {
      "patterns": [
        {
          "comment": "quantity prefixes in parameter lists",
          "match": "(?<=[(,]\\s*)([01])\\s+(?=[A-Za-z_])",
          "name": "storage.modifier.quantity.gpp"
        }
      ]
    },
    "gpp-directives": {
      "patterns": [
        {
          "match": "//gpp:\\w+.*$",
          "name": "comment.line.directive.gpp"
        }
      ]
    }
  }
}
