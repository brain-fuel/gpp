{
  "name": "goplus",
  "displayName": "Go+ (goplus)",
  "description": "Go+ language support: syntax highlighting and the goplus language server (diagnostics, hover, definition, completion).",
  "version": "0.9.0",
  "publisher": "goforge-dev",
  "license": "SEE LICENSE IN ../../LICENSE",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages"],
  "repository": { "type": "git", "url": "https://github.com/brain-fuel/goplus" },
  "main": "./out/extension.js",
  "activationEvents": ["onLanguage:goplus"],
  "contributes": {
    "languages": [
      {
        "id": "goplus",
        "aliases": ["Go+", "goplus"],
        "extensions": [".gp"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "goplus",
        "scopeName": "source.gp",
        "path": "./syntaxes/goplus.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.24.0"
  }
}
