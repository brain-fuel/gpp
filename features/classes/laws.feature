      """
      package main

      type Mode enum {
      	Fast
      	Careful(retries int)
      }

      type Runner[T any] class {
      	Run(host T, m Mode) int
      	law NonNegative(host T, m Mode) {
      		return Run(host, m) >= 0
      	}
      }

      type good struct{}

      instance Good Runner[good] {
      	Run(host good, m Mode) int {
      		match m {
      		case Fast():
      			return 1
      		case Careful(r):
      			if r < 0 {
      				return 0
      			}
      			return r
      		}
      		return 0
      	}
      }

      type bad struct{}

      instance Bad Runner[bad] {
      	Run(host bad, m Mode) int {
      		match m {
      		case Fast():
      			return 1
      		case Careful(r):
      			return r
      		}
      		return 0
      	}
      }

      func main() {}
