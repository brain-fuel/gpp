Feature: Law tests are generated by default
  Every instance whose class closure declares laws and whose type argument
  is concrete gets a generated <file>_gpp_laws_test.go with rapid
  properties exercising every inherited law (through the upcasts).
  Knobs, via //gpp:laws on the instance: `off` suppresses; generic
  instances are skipped unless given explicit instantiations
  (`//gpp:laws [int] [string]`); `gen=Name` selects a custom rapid
  generator. Law tests are generated output: gen -check covers them and
  orphaned ones are removed.

  Background:
    Given a module "example.com/demo" using rapid for law tests

  Scenario: Default-on generation, inherited laws, off, and generic opt-in
    Given a G++ file "main.gpp":
      """
      package main

      import (
      	"fmt"
      	"reflect"
      )

      type Semigroup[T any] class {
      	Combine(a, b T) T
      	law Assoc(a, b, c T) { return reflect.DeepEqual(Combine(Combine(a, b), c), Combine(a, Combine(b, c))) }
      }

      type Monoid[T any] class {
      	Semigroup[T]
      	Empty() T
      	law LeftId(a T) { return reflect.DeepEqual(Combine(Empty(), a), a) }
      }

      instance IntAdd Monoid[int] {
      	Combine(a, b int) int { return a + b }
      	Empty() int { return 0 }
      }

      //gpp:laws off
      instance IntMul Monoid[int] {
      	Combine(a, b int) int { return a * b }
      	Empty() int { return 1 }
      }

      //gpp:laws [int] [string]
      instance SliceConcat[T any] Monoid[[]T] {
      	Combine(a, b []T) []T { return append(append([]T{}, a...), b...) }
      	Empty() []T { return nil }
      }

      func main() { fmt.Println("ok") }
