(*
  Go+ grammar, v0.5.0 — expressed as a delta over the Go specification and
  spec/grammar-v0.4.0.ebnf. Every production not listed here is exactly the
  Go production; all prior Go+ extensions carry forward unchanged.

  `class`, `instance`, and `law` are CONTEXTUAL identifiers:
  - `class` is claimed only in a type spec's type position when followed
    immediately by "{" (the enum discipline). `type T class` alone stays an
    identifier type named class.
  - `instance` is claimed only at the top of a declaration when followed by
    an identifier. No valid Go top-level declaration begins with an
    identifier, so the claim is a strict superset.
  - `law` is claimed only inside a claimed class body.

  This file and the Godog feature suite under features/ are together the
  authoritative specification of Go+.
*)

(* ------------------------- Class declarations --------------------------- *)

TypeSpecType = GoType | EnumType | ClassType .
ClassType    = "class" "{" { ClassMember } "}" .

ClassMember  = ClassEmbed | ClassOp | ClassLaw .
ClassEmbed   = ClassRefType ";" .                     (* Semigroup[T] | pkg.Semigroup[T] *)
ClassOp      = identifier Parameters [ Type ] [ Block ] ";" .
ClassLaw     = "law" identifier Parameters Block ";" .
ClassRefType = ( identifier | QualifiedIdent ) "[" TypeList "]" .

(*
  - A class has EXACTLY ONE type parameter in v0.5.0.
  - Class declarations cannot be type aliases.
  - A ClassOp with a Block declares a DEFAULT implementation: instances may
    omit the operation and receive the default. Default and law bodies see
    the class's own operations as bare names (Combine, Empty, …).
  - A ClassLaw is a named boolean predicate over the operations; the bool
    result is implicit and the body is required.
  - ClassEmbed builds the hierarchy; diamonds collapse (an operation
    reachable by several paths is one operation). Conflicting signatures
    for the same operation name are an error.
*)

(* ------------------------ Instance declarations ------------------------- *)

TopLevelDecl   = GoTopLevelDecl | InstanceDecl .
InstanceDecl   = "instance" identifier [ TypeParameters ] InstanceHead
                 "{" { InstanceMember } "}" .
InstanceHead   = ( identifier | QualifiedIdent ) "[" TypeList "]" .
InstanceMember = identifier Parameters [ Type ] Block ";" .

(*
  - Instances are NAMED; several instances of one (class, type) pair may
    coexist — ambiguity at a use site is a hard error naming the
    candidates, resolved by passing the witness explicitly.
  - The head must be a fully applied class (Monoid[int]); generic
    instances declare type parameters (instance SliceConcat[T any]
    Monoid[[]T]) and lower to functions.
  - Every member requires a body; members may reference sibling and
    inherited operations (including defaults) as bare names.
*)

(* ---------------------------- Constraints ------------------------------- *)

TypeParamConstraint = GoTypeConstraint
                    | ClassName
                    | "interface" "{" ClassName { ";" ClassName } "}" .
ClassName           = identifier | QualifiedIdent .

(*
  - A bare class name in a FUNCTION type-parameter constraint position
    (func Accumulate[T Monoid](xs []T) T) constrains T by that class; the
    lowering prepends one witness value parameter per constraint and every
    call site receives the resolved instance implicitly.
  - The interface-literal spelling composes several class constraints on
    one parameter (Lean-style multiple witnesses). Mixing classes with
    ordinary interface elements in one literal is an error in v0.5.0.
  - Class constraints are legal only on function (and method) type
    parameters, not on type declarations.
  - Resolution: candidates are the instances declared in the current
    package plus exported instances of the file's direct imports; an
    instance of a STRONGER class satisfies a weaker constraint via the
    generated upcast (full subsumption; same-instance diamond paths are
    one candidate). The explicit escape hatch is calling the lowered
    signature directly: Accumulate(IntAdd, xs).
  - Inside constrained code, bare operation names resolve against the
    in-scope constraints; a name that also resolves in ordinary scope is a
    hard error demanding qualification. Receiver sugar a.Combine(b) and
    pipe segments xs |> Combine(x) apply when the receiver/flowing type is
    a constrained type parameter.
*)

(* ------------------------------- Laws ----------------------------------- *)

(*
  Law tests are GENERATED BY DEFAULT for every instance whose class
  closure declares laws and whose type arguments are concrete, into
  <file>_gp_laws_test.go (rapid properties). Knobs, as //goplus:laws
  directives: `off` suppresses; generic instances opt in with explicit
  instantiations (//goplus:laws [int] [string]); gen=Name selects a custom
  rapid generator; a package-level out=<reldir> emits an external test
  package.
*)
