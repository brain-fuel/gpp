(*
  G++ grammar, v0.4.0 — expressed as a delta over the Go specification and
  spec/grammar-v0.3.0.ebnf. Every production not listed here is exactly the
  Go production; the v0.1.0 MethodDecl, v0.2.0 EnumType/MatchStmt, and
  v0.3.0 PipeExpr/PipeStage extensions are carried forward unchanged.
  ComposeExpr is restated below to admit ">=>".

  "?" is not a Go token: the scanner reports it as an illegal character.
  G++ claims it only as a POSTFIX suffix written immediately after the
  expression it modifies, with no intervening whitespace, comments, or
  newlines. A spaced or freestanding "?" (e.g. `f() ?`, `a ? b : c`,
  `var ? int`) is not claimed and keeps the stock scanner error.

  ">=>" is a token *sequence*: ">=" immediately followed by ">". It is
  invalid Go in every expression position, so claiming it preserves the
  strict superset. Near-misses (">= >", ">=>=", ">=>>") are not claimed.

  This file and the Godog feature suite under features/ are together the
  authoritative specification of G++.
*)

(* --------------------------- Failure suffix ----------------------------- *)

PrimaryExpr   = GoPrimaryExpr | PrimaryExpr "?" .
GoPrimaryExpr = (* Go's PrimaryExpr production, verbatim *) .

(*
  - "?" binds tightest, on the same footing as call/index/selector
    suffixes: `a? + b` is `(a?) + b`; `f()?.g()` chains; `-x?` is
    `-(x?)`. Multiple "?" in one expression are all claimed: `f(g()?)?`.
  - "?" does not disturb automatic semicolon insertion.
  - Semantics (normative, resolution-time): `e?` propagates failure to
    the enclosing function — an (…, error)-returning function early-
    returns zero values and the error; a Result-returning function
    returns Err. Operands may be Result values or (…, error)-shaped
    calls. On a pipeline stage, "?" applies to the STAGE RESULT and
    leaves the railway.
*)

(* ------------------- Composition (restated for ">=>") ------------------- *)

ComposeExpr = GoExpression { compose_op GoExpression } .
compose_op  = ">>>" | ">=>" .

(*
  ">>>" and ">=>" share one precedence level — between "|>" and "||" —
  left-associative; a contiguous run of either or both flattens into ONE
  chain recording each link's operator: `f >=> g >>> h` folds as
  `(f >=> g) >>> h`. ">=>" composes on the railway (Kleisli): switch
  operands (T → Result[U, E]) bind, plain operands lift, (U, error)
  operands adapt; a chain in which no operand can fail is an error.
*)

(* ---------------------- Expression conditionals ------------------------- *)

Operand   = GoOperand | IfExpr | SwitchExpr | MatchExpr .
GoOperand = (* Go's Operand production, verbatim *) .

IfExpr     = "if" Condition ExprBlock "else" ( IfExpr | ExprBlock ) .
Condition  = Expression .
ExprBlock  = "{" Expression [ ";" ] "}" .

SwitchExpr    = "switch" [ Condition ] "{" { SwitchExprArm } "}" .
SwitchExprArm = ( "case" ExpressionList | "default" ) ":" Expression [ ";" ] .

MatchExpr    = "match" Condition "{" { MatchExprArm } "}" .
MatchExprArm = "case" [ identifier ":=" ] MatchPattern ":" Expression [ ";" ] .
MatchPattern = (* v0.2.0 Pattern production, verbatim *) .

(*
  - "if" and "switch" are Go keywords that can never begin a Go operand,
    so the expression forms are trivially claimable; statement-position
    if/switch/match are entirely unchanged.
  - Expression-position `match` is contextual and claimed only when the
    next token begins a subject AND cannot continue a valid Go
    expression or statement whose operand is the identifier `match`:
    identifier, literal, "func", "struct", "map", "chan", "interface",
    "!". In particular "+", "-", "*", "&", "^", "<-", ".", "(", "[",
    "{" are NOT claimed (`y := match + 1` stays Go; `match <- ch` stays
    a send). Parenthesize such subjects: `match (-x) { … }`.
  - Conditions/tags/subjects parse with the statement forms' composite-
    literal restriction. No init statements. `else` is REQUIRED and
    follows "}" on the same line; else-if chains allowed. An ExprBlock
    holds exactly one expression (the optional ";" is the automatic
    newline semicolon). Arm values are full G++ expressions — pipelines,
    "?", and nested expression conditionals all nest.
  - `switch`-expr arms have no `fallthrough` and (normatively) require a
    `default` arm; `match`-expr has no `default` (use `case _:`) and is
    exhaustiveness-checked like the v0.2.0 match statement.
  - Value typing (normative): the context's expected type when one
    exists and every arm is assignable to it; otherwise all arms must
    share one identical default type.
  - Both "?" and expression conditionals lower to statements hoisted
    before their enclosing statement; hoisted sites evaluate before the
    rest of that statement, in source order. They may not appear in for
    conditions/post statements, else-if conditions, to the right of
    "&&"/"||", in switch case values, select communications, assignment
    left-hand sides, or at package level.
*)
